# apps/api/.env.example
# Copy to .env and fill in your values

PORT=3001
MONGODB_URI=mongodb://localhost:27017/farhty
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Single admin account — hash your password with bcrypt before putting it here
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Your WhatsApp number for the store buy flow (international format, no +)
WHATSAPP_NUMBER=201000000000

# InstaPay ID shown in the store buy flow
INSTAPAY_ID=your_instapay_id

# Vodafone Cash number shown in the store buy flow
VODAFONE_CASH_NUMBER=01000000000
